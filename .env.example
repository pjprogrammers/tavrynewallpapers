# =============================================================================
# Tavryne Wallpapers — environment variables
# =============================================================================
# Copy this file to `.env.local` (which is gitignored) and fill in the values.
# The `npm run role` and `npm run seed-wallpapers` scripts read the
# FIREBASE_SERVICE_ACCOUNT_* values from the environment.
# =============================================================================

# -----------------------------------------------------------------------------
# 🔥 FIREBASE WEB SDK (NEXT_PUBLIC_* — exposed to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

#Cloudinary Setup Variables For Avatar Uploads Feature
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# -----------------------------------------------------------------------------
# 🛡️ FIREBASE APP CHECK (reCAPTCHA — protects Firestore / Storage)
# -----------------------------------------------------------------------------
# Get the key from Google Cloud Console → reCAPTCHA Enterprise, then register
# the site key for your domains (e.g. tavrynewallpapers.vercel.app and
# localhost for development).
#
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# -----------------------------------------------------------------------------
# 🔐 FIREBASE ADMIN SDK (for `npm run role` and `npm run seed-wallpapers`)
# -----------------------------------------------------------------------------
# Generate a service account key:
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Then either:
#  (a) Set FIREBASE_SERVICE_ACCOUNT_KEY to the entire JSON contents (or its
#      base64 encoding) — RECOMMENDED FOR VERCEL
#  (b) Set FIREBASE_SERVICE_ACCOUNT_PATH to the absolute path of the JSON file
#      — CONVENIENT FOR LOCAL DEVELOPMENT
#  (c) Set GOOGLE_APPLICATION_CREDENTIALS to the JSON file path — GOOGLE STANDARD
#  (d) Drop `serviceAccountKey.json` in the project root — GITIGNORED
#
# Do NOT commit the service account JSON to version control.

# FIREBASE_SERVICE_ACCOUNT_KEY=
# FIREBASE_SERVICE_ACCOUNT_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=
