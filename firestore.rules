rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================================================
       🔐 HELPER FUNCTIONS
    ========================================================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isModerator() {
      return isAuthenticated() && (
        request.auth.token.moderator == true ||
        request.auth.token.admin == true
      );
    }

    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function isValidUrl(value) {
      return value is string && (value.size() == 0 || value.matches('^https?://[^\\s]+$'));
    }

    /* =========================================================
       👤 USERS COLLECTION
    ========================================================= */
    match /users/{userId} {
      // Anyone can read user profiles (for display)
      allow read: if true;

      // Users can update their own profile — only whitelisted fields allowed
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data)
            .changedKeys()
            .hasOnly(['displayName', 'photoURL', 'updatedAt', 'lastLogin']);

      // Users can create their own document (during signup)
      // Only default roles are allowed; uid must match; isActive must be true;
      // provider must be a known Firebase Auth provider.
      allow create: if isOwner(userId)
        && request.resource.data.roles == { admin: false, moderator: false }
        && request.resource.data.uid == userId
        && request.resource.data.isActive == true
        && request.resource.data.provider in ['password', 'google.com', 'github.com', 'facebook.com', 'twitter.com', 'apple.com', 'microsoft.com', 'yahoo.com', 'phone', 'anonymous']
        && isValidString(request.resource.data.displayName, 0, 100)
        && isValidString(request.resource.data.email, 0, 254)
        && isValidUrl(request.resource.data.photoURL);

      // User doc deletion is blocked — deactivate via isActive instead
      allow delete: if false;

      /* =========================================================
         ❤️ FAVORITES SUBCOLLECTION (per-user)
         Path: users/{userId}/favorites/{wallpaperId}
      ========================================================= */
      match /favorites/{wallpaperId} {
        // Anyone can see favorites (for UI display)
        allow read: if true;
        // Users manage their own favorites — no create/update distinction,
        // the client uses setDoc with merge to toggle on/off.
        allow write: if isOwner(userId);
      }

      /* =========================================================
         ⬇️ DOWNLOADS SUBCOLLECTION (per-user)
         Path: users/{userId}/downloads/{wallpaperId}
      ========================================================= */
      match /downloads/{wallpaperId} {
        // Users can read their own download history
        allow read: if isOwner(userId);
        // Anyone can record a download (anonymous users can download)
        allow create: if true;
        // Users can delete their own downloads
        allow delete: if isOwner(userId);
      }
    }

    /* =========================================================
       🖼️ WALLPAPERS COLLECTION
    ========================================================= */
    match /wallpapers/{wallpaperSlug} {
      // Public read: only published, non-deleted wallpapers
      // Moderators/admins can read all (drafts, deleted, etc.)
      allow read: if isModerator()
        || (resource.data.published == true && resource.data.deleted != true);

      // Only moderators/admins can create wallpapers.
      allow create: if isModerator()
        && isValidString(request.resource.data.title, 1, 200);

      // Anyone can increment tracking counters (views, impressions,
      // clicks, downloads). Unauthenticated visitors count too.
      // Each counter can increase by at most 1 per request.
      allow update: if (
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'views', 'impressions', 'clicks', 'downloads'
        ])
      );

      // Authenticated users can toggle the favorites counter
      // (used by the toggleFavorite transaction).
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'favorites'
        ]);

      // Moderators and admins can update any wallpaper.
      // Locked fields cannot be changed.
      allow update: if isModerator()
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'slug',
            'id',
            'filename',
            'createdAt',
            'uploaderId'
          ])
        );

      // Only admins can delete wallpapers
      allow delete: if isAdmin();
    }

    /* =========================================================
       📜 WALLPAPER EDIT HISTORY
       Path: wallpaperEditHistory/{wallpaperSlug}/edits/{editId}

       Two match blocks are required so that BOTH a regular
       collection query AND a `collectionGroup('edits')` query
       (used by the admin / edits page) succeed. Without the
       wildcard match below, Firestore rejects the collectionGroup
       query with "Missing or insufficient permissions" even when
       the nested match allows `read: if true`.
    ========================================================= */
    match /wallpaperEditHistory/{wallpaperSlug} {
      // Anyone can read the edit history (transparency)
      allow read: if true;

      // Only moderators can create entries (via the edit modal)
      // The client must be authenticated AND have the moderator or
      // admin custom claim.
      match /edits/{editId} {
        allow read: if true;
        allow create: if isModerator()
          && request.resource.data.wallpaperSlug == wallpaperSlug
          && request.resource.data.editedBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'changes', 'reason', 'wallpaperSlug', 'editedBy', 'editedAt', 'type'
          ]);
        // History is append-only; no updates / deletes from the client.
        allow update, delete: if isAdmin();
      }
    }

    // ✅ Wildcard match for collectionGroup('favorites') queries
    // (used by hardDeleteWallpaper to clean up orphaned favorites).
    match /{path=**}/favorites/{id} {
      allow read: if true;
      // Only the owning user can write; admins can delete orphans
      allow write: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // ✅ Wildcard match for collectionGroup('downloads') queries
    // (used by hardDeleteWallpaper to clean up orphaned downloads).
    match /{path=**}/downloads/{id} {
      allow read: if request.auth.uid == resource.data.userId || isAdmin();
      allow create: if true;
      allow delete: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // ✅ Wildcard match for collectionGroup('edits') queries.
    // Firestore requires an explicit rule that matches the doc
    // shape regardless of its parent path. The condition here
    // mirrors the nested `edits` rule above.
    match /{path=**}/edits/{editId} {
      allow read: if true;
      allow create: if isModerator()
        && request.resource.data.editedBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'changes', 'reason', 'wallpaperSlug', 'editedBy', 'editedAt', 'type'
        ]);
      allow update, delete: if isAdmin();
    }

    /* =========================================================
       🏷️ CATEGORIES COLLECTION
    ========================================================= */
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isModerator()
        && isValidString(request.resource.data.name, 1, 100);
      allow update: if isModerator()
        && request.resource.data.name is string;
      allow delete: if isModerator();
    }

    /* =========================================================
       🏷️ TAGS COLLECTION
    ========================================================= */
    match /tags/{tagId} {
      allow read: if true;
      allow create: if isModerator()
        && isValidString(request.resource.data.name, 1, 100);
      allow update: if isModerator()
        && request.resource.data.name is string;
      allow delete: if isModerator();
    }

    /* =========================================================
       🏷️ META COLLECTION (legacy, kept for seed data)
    ========================================================= */
    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* =========================================================
       ⏱️ RATE LIMITS COLLECTION (Server-side only)
    ========================================================= */
    match /rateLimits/{rateLimitId} {
      // Client-side rate limiting is handled in browser sessionStorage
      // Server-side rate limits would be managed by Cloud Functions
      allow read, write: if false;
    }
  }
}
