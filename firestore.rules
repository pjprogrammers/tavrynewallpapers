rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================================================
       🔐 HELPER FUNCTIONS
    ========================================================= */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isModerator() {
      return isAuthenticated() && (
        request.auth.token.moderator == true ||
        request.auth.token.admin == true
      );
    }

    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function isValidUrl(value) {
      return value is string && (value.size() == 0 || value.matches('^https?://[^\\s]+$'));
    }

    function isValidNumber(value, min, max) {
      return value is number && value >= min && value <= max;
    }

    /* =========================================================
       👤 USERS COLLECTION
    ========================================================= */
    match /users/{userId} {
      // Anyone can read user profiles (for display)
      allow read: if true;

      // The user can update their own profile, but cannot change
      // the `roles` field (which mirrors custom claims).
      allow update: if isOwner(userId)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'roles',
            'email',
            'uid',
            'provider',
            'createdAt',
            'isActive'
          ])
        );

      // Users can create their own document (during signup)
      allow create: if isOwner(userId)
        && isValidString(request.resource.data.displayName, 0, 100)
        && isValidString(request.resource.data.email, 0, 254)
        && isValidUrl(request.resource.data.photoURL);

      // Only admins can delete a user document
      allow delete: if isAdmin();
    }

    /* =========================================================
       🖼️ WALLPAPERS COLLECTION
    ========================================================= */
    match /wallpapers/{wallpaperSlug} {
      // Wallpapers are publicly readable
      allow read: if true;

      // Public create (e.g. user uploads) — anyone authenticated
      // can create a new wallpaper doc with a valid slug.
      allow create: if isAuthenticated()
        && isValidString(request.resource.data.slug, 1, 200)
        && isValidString(request.resource.data.title, 1, 200)
        && wallpaperSlug == request.resource.data.slug;

      // ✅ Moderators (and admins) can update any wallpaper.
      // Locked fields (slug, id, filename) cannot be changed.
      allow update: if isModerator()
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'slug',
            'id',
            'filename',
            'createdAt',
            'uploaderId'
          ])
        );

      // Only admins can delete wallpapers
      allow delete: if isAdmin();
    }

    /* =========================================================
       📜 WALLPAPER EDIT HISTORY
       Path: wallpaperEditHistory/{wallpaperSlug}/edits/{editId}
    ========================================================= */
    match /wallpaperEditHistory/{wallpaperSlug} {
      // Anyone can read the edit history (transparency)
      allow read: if true;

      // Only moderators can create entries (via the edit modal)
      // The client must be authenticated AND have the moderator or
      // admin custom claim.
      match /edits/{editId} {
        allow read: if true;
        allow create: if isModerator()
          && request.resource.data.wallpaperSlug == wallpaperSlug
          && request.resource.data.editedBy == request.auth.uid;
        // History is append-only; no updates / deletes from the client.
        allow update, delete: if isAdmin();
      }
    }

    /* =========================================================
       📊 WALLPAPER STATS COLLECTION
    ========================================================= */
    match /wallpaperStats/{wallpaperId} {
      // Stats are publicly readable
      allow read: if true;

      // Allow anyone to update stats (atomic increments) for tracking
      // views/downloads. The client uses `increment()` operations.
      allow write: if true;
    }

    /* =========================================================
       👁️ VIEWS SUB-COLLECTION
    ========================================================= */
    match /wallpapers/{wallpaperId}/views/{viewId} {
      // Anyone can record views
      allow read, create: if true;
    }

    /* =========================================================
       ❤️ FAVORITES COLLECTION
    ========================================================= */
    match /favorites/{favoriteId} {
      // Anyone can read favorites (to show counts)
      allow read: if true;

      // Users can only manage their own favorites
      // Ensure favoriteId matches userId_wallpaperId pattern
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && favoriteId == request.auth.uid + '_' + request.resource.data.wallpaperId;

      // Users can only delete their own favorites
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    /* =========================================================
       👍 LIKES COLLECTION
    ========================================================= */
    match /likes/{likeId} {
      // Anyone can read likes (to show counts)
      allow read: if true;

      // Users can only manage their own likes
      // Ensure likeId matches userId_wallpaperId pattern
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && likeId == request.auth.uid + '_' + request.resource.data.wallpaperId;

      // Users can only delete their own likes
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    /* =========================================================
       ⬇️ DOWNLOADS COLLECTION
    ========================================================= */
    match /downloads/{downloadId} {
      // Users can read their own downloads
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Anyone can create downloads (for tracking anonymous downloads)
      // userId is optional for anonymous downloads
      allow create: if true;

      // Downloads can only be deleted by authenticated users who own them
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    /* =========================================================
       👁️ IMPRESSIONS COLLECTION
    ========================================================= */
    match /impressions/{impressionId} {
      // Impressions are publicly readable for analytics
      allow read: if true;

      // Anyone can record impressions
      allow create: if true;
    }

    /* =========================================================
       👆 CLICKS COLLECTION
    ========================================================= */
    match /clicks/{clickId} {
      // Clicks are publicly readable for analytics
      allow read: if true;

      // Anyone can record clicks
      allow create: if true;
    }

    /* =========================================================
       🏷️ META COLLECTION (categories, tags seeds)
    ========================================================= */
    match /meta/{docId} {
      // Public read (for tag/category lists, autocomplete, etc.)
      allow read: if true;

      // Only admins can write
      allow write: if isAdmin();
    }

    /* =========================================================
       ⏱️ RATE LIMITS COLLECTION (Server-side only)
    ========================================================= */
    match /rateLimits/{rateLimitId} {
      // Client-side rate limiting is handled in browser sessionStorage
      // Server-side rate limits would be managed by Cloud Functions
      allow read, write: if false;
    }
  }
}
